# ============================
# Ghostty Configuration
# ============================

# --- 字体 ---
font-family = JetBrainsMono Nerd Font
font-size = 14
font-feature = calt
font-feature = liga
font-thicken = true
adjust-cell-height = 25%

# --- 主题 ---
theme = Rose Pine Dawn

# --- 窗口外观 ---
background-opacity = 0.92
background-blur-radius = 20
window-decoration = true
macos-titlebar-style = tabs
macos-option-as-alt = true
window-padding-x = 10
window-padding-y = 8
window-padding-color = extend
window-inherit-working-directory = true
window-save-state = always
confirm-close-surface = always

# --- Quick Terminal（全局 Cmd+` 呼出下拉终端）---
quick-terminal-position = top
quick-terminal-screen = main
quick-terminal-animation-duration = 0.15

# --- Shell 集成 ---
shell-integration = zsh
shell-integration-features = cursor,sudo,title

# --- 光标 ---
cursor-style = block
cursor-style-blink = false

# --- 滚动 ---
scrollback-limit = 100000
mouse-scroll-multiplier = 1

# --- 复制粘贴 ---
copy-on-select = clipboard
clipboard-paste-protection = true

# --- 链接点击 ---
link-url = true

# --- 关闭响铃 ---
bell-features = no-system,no-audio

# --- 撤销（关闭 tab/split 后可恢复）---
undo-timeout = 30s

# ============================
# 快捷键
# ============================

# --- 全局呼出 Quick Terminal ---
keybind = global:cmd+shift+apostrophe=toggle_quick_terminal

# --- 分屏：统一映射为 tmux 指令（\x17 = Ctrl-w 前缀）---
# Cmd+D       → tmux 左右分栏 (Ctrl-w |)
# Cmd+Shift+D → tmux 上下分栏 (Ctrl-w -)
keybind = cmd+d=text:\x17|
keybind = cmd+shift+d=text:\x17-

# --- 分屏：跳转统一为 tmux pane 切换 (Ctrl-w h/j/k/l) ---
keybind = cmd+shift+h=text:\x17h
keybind = cmd+shift+l=text:\x17l
keybind = cmd+shift+k=text:\x17k
keybind = cmd+shift+j=text:\x17j

# --- 分屏：调整大小 → tmux resize pane ---
# Ctrl+Shift+Arrow → Ctrl-w + Ctrl-h/j/k/l
keybind = ctrl+shift+left=text:\x17\x08
keybind = ctrl+shift+right=text:\x17\x0c
keybind = ctrl+shift+up=text:\x17\x0b
keybind = ctrl+shift+down=text:\x17\x0a

# --- 分屏：缩放 / 均分 → tmux zoom / tiled ---
keybind = cmd+shift+enter=text:\x17z
keybind = cmd+shift+equal=text:\x17=

# --- Tab = tmux window ---
# Cmd+T → 新建 window，Cmd+W → 关闭 pane
keybind = cmd+t=text:\x17c
keybind = cmd+w=text:\x17x
# Cmd+Shift+[ / ] → 上/下一个 window
keybind = cmd+shift+left_bracket=text:\x17p
keybind = cmd+shift+right_bracket=text:\x17n

# --- 滚动 ---
keybind = cmd+up=scroll_to_top
keybind = cmd+down=scroll_to_bottom
keybind = cmd+shift+up=jump_to_prompt:-1
keybind = cmd+shift+down=jump_to_prompt:1

# --- 字体大小 ---
keybind = cmd+equal=increase_font_size:1
keybind = cmd+minus=decrease_font_size:1
keybind = cmd+zero=reset_font_size

# --- 实用功能 ---
keybind = cmd+shift+c=copy_to_clipboard
keybind = cmd+shift+v=paste_from_clipboard
keybind = cmd+k=clear_screen
keybind = cmd+shift+f=start_search
keybind = cmd+shift+o=write_scrollback_file:open
keybind = cmd+shift+p=toggle_command_palette
keybind = cmd+shift+t=toggle_window_float_on_top
keybind = cmd+shift+backslash=toggle_background_opacity
